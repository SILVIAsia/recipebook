{% extends 'base.html.twig' %}

{% block body %}
    <div class="flex min-h-screen">

        {# Menu gauche #}
        <div class="w-1/4 bg-slate-100 p-6">
            <h2 class="font-bold text-lg text-pink-500 mb-4">{{ app.user.name }}</h2>
            <ul class="space-y-2">
                <li>
                    <a href="{{ path('mon_espace') }}" class="text-slate-700 hover:text-pink-400 block py-2">Mes
                        recettes</a>
                </li>
                <li>
                    <a href="{{ path('mon_espace_profil') }}" class="text-slate-700 hover:text-pink-400 block py-2">Mon
                        profil</a>
                </li>
                <li>
                    <a href="{{ path('recette_create') }}" class="text-slate-700 hover:text-pink-400 block py-2">Nouvelle
                        recette</a>
                </li>

                {% if is_granted('ROLE_ADMIN') %}
                    <li class="border-t border-slate-300 mt-4 pt-4">
                        <a href="{{ path('admin_dashboard') }}"
                           class="text-pink-400 font-semibold hover:text-pink-600 block py-2">Administration</a>
                    </li>

                {% endif %}
            </ul>
        </div>

        {# Contenu #}
        <div class="w-3/4 p-6">

            {% block user_content %}{% endblock %}
        </div>

    </div>

{% endblock %}
