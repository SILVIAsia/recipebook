<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <meta name="viewport"
              content="width=device-width, user-scalable=no, initial-scale=1.0, maximum-scale=1.0, minimum-scale=1.0">
        <meta http-equiv="X-UA-Compatible" content="ie=edge">

        <title>{% block title %}Recettes du CDM!{% endblock %}</title>
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Nunito:ital,wght@0,200..1000;1,200..1000&family=Roboto:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">
        <link rel="icon" href="{{ asset('images/favicomlogo.png') }}" type="image/x-icon">

        {% block stylesheets %}
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}

    </head>

    <body>
        <header>
            {% include("views/nav.html.twig") %}

           <a href="{{ path('main_home') }}" title="Aller a l'accueil">
               <img src="{{ asset('images/logocdm1.png')}}">
           </a>


        </header>

        <main>
            {% block body %}{% endblock %}
        </main>

        <footer>
            &copy; Centre de Marais {{"now"|date("Y") }}
        </footer>

    </body>
</html>
