{% extends 'base.html.twig' %}

{% block body %}
    <div class="p-6 max-w-4xl">
        <a href="{{ path('admin_animateurs') }}" class="text-pink-400 hover:text-pink-600 mb-4 block">← Retour</a>

        <h1 class="text-2xl font-bold text-pink-500 mb-2">{{ user.name }} {{ user.lastname }}</h1>
        <p class="text-slate-500 mb-1">{{ user.email }}</p>
        <p class="text-slate-500 mb-6">{{ user.username }}</p>

        <h2 class="text-xl font-semibold mb-4">Recettes</h2>

        {% if user.recettes is not empty %}
            {% for recette in user.recettes %}
                <div class="border border-slate-200 rounded-lg p-4 mb-3">
                    <a href="{{ path('recette_detail', {id: recette.id}) }}" class="font-semibold hover:text-pink-400">
                        {{ recette.titre }}
                    </a>
                    <p class="text-slate-500 text-sm mt-1">{{ recette.dateCreated | date("d-m-Y") }}</p>
                </div>
            {% endfor %}
        {% else %}
            <p class="text-slate-400">Aucune recette</p>
        {% endif %}
    </div>
{% endblock %}
