{% extends 'admin/layout.html.twig' %}

{% block admin_content %}
    <div class="max-w-md">
        <h1 class="text-3xl font-bold text-pink-500 mb-8">Modifier {{ user.name }}</h1>

        {{ form_errors(form) }}

        {{ form_start(form) }}

        <div class="mb-4">
            {{ form_label(form.name, null, {'attr': {'class': 'block mb-1 font-semibold'}}) }}
            {{ form_widget(form.name, {'attr': {'class': 'bg-slate-100 rounded-lg px-4 py-3 w-full text-black focus:outline-none focus:ring-2 focus:ring-teal-500'}}) }}
            <div class="text-red-600 text-sm">{{ form_errors(form.name) }}</div>
        </div>

        <div class="mb-4">
            {{ form_label(form.lastname, null, {'attr': {'class': 'block mb-1 font-semibold'}}) }}
            {{ form_widget(form.lastname, {'attr': {'class': 'bg-slate-100 rounded-lg px-4 py-3 w-full text-black focus:outline-none focus:ring-2 focus:ring-teal-500'}}) }}
            <div class="text-red-600 text-sm">{{ form_errors(form.lastname) }}</div>
        </div>

        <div class="mb-4">
            {{ form_label(form.username, null, {'attr': {'class': 'block mb-1 font-semibold'}}) }}
            {{ form_widget(form.username, {'attr': {'class': 'bg-slate-100 rounded-lg px-4 py-3 w-full text-black focus:outline-none focus:ring-2 focus:ring-teal-500'}}) }}
            <div class="text-red-600 text-sm">{{ form_errors(form.username) }}</div>
        </div>

        <div class="mb-6">
            {{ form_label(form.email, null, {'attr': {'class': 'block mb-1 font-semibold'}}) }}
            {{ form_widget(form.email, {'attr': {'class': 'bg-slate-100 rounded-lg px-4 py-3 w-full text-black focus:outline-none focus:ring-2 focus:ring-teal-500'}}) }}
            <div class="text-red-600 text-sm">{{ form_errors(form.email) }}</div>
        </div>

        <button type="submit" class="bg-pink-400 text-white w-full py-3 rounded-lg font-semibold hover:bg-pink-500">
            Enregistrer
        </button>

        {{ form_end(form) }}
    </div>
{% endblock %}

{% block title %}Modifier animateur | {{ parent() }}{% endblock %}
