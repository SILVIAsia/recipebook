{% extends 'admin/layout.html.twig' %}


{% block title %}Inscription | {{ parent() }}{% endblock %}

{% block admin_content %}
    <div class="max-w-md">
        <h1 class="text-3xl font-bold text-pink-500 mb-8">Inscrire un animateur</h1>

        {{ form_errors(registrationForm) }}

        {{ form_start(registrationForm) }}

        <div class="mb-4">
            {{ form_label(registrationForm.email, null, {'attr': {'class': 'block mb-1 font-semibold'}}) }}
            {{ form_widget(registrationForm.email, {'attr': {'class': 'bg-slate-100 rounded-lg px-4 py-3 w-full text-black focus:outline-none focus:ring-2 focus:ring-teal-500'}}) }}
            <div class="text-red-600 text-sm">{{ form_errors(registrationForm.email) }}</div>
        </div>

        <div class="mb-4">
            {{ form_label(registrationForm.name, null, {'attr': {'class': 'block mb-1 font-semibold'}}) }}
            {{ form_widget(registrationForm.name, {'attr': {'class': 'bg-slate-100 rounded-lg px-4 py-3 w-full text-black focus:outline-none focus:ring-2 focus:ring-teal-500'}}) }}
            <div class="text-red-600 text-sm">{{ form_errors(registrationForm.name) }}</div>
        </div>

        <div class="mb-4">
            {{ form_label(registrationForm.lastname, null, {'attr': {'class': 'block mb-1 font-semibold'}}) }}
            {{ form_widget(registrationForm.lastname, {'attr': {'class': 'bg-slate-100 rounded-lg px-4 py-3 w-full text-black focus:outline-none focus:ring-2 focus:ring-teal-500'}}) }}
            <div class="text-red-600 text-sm">{{ form_errors(registrationForm.lastname) }}</div>
        </div>

        <div class="mb-4">
            {{ form_label(registrationForm.username, null, {'attr': {'class': 'block mb-1 font-semibold'}}) }}
            {{ form_widget(registrationForm.username, {'attr': {'class': 'bg-slate-100 rounded-lg px-4 py-3 w-full text-black focus:outline-none focus:ring-2 focus:ring-teal-500'}}) }}
            <div class="text-red-600 text-sm">{{ form_errors(registrationForm.username) }}</div>
        </div>

        <div class="mb-6">
            {{ form_label(registrationForm.plainPassword, 'Mot de passe', {'attr': {'class': 'block mb-1 font-semibold'}}) }}
            {{ form_widget(registrationForm.plainPassword, {'attr': {'class': 'bg-slate-100 rounded-lg px-4 py-3 w-full text-black focus:outline-none focus:ring-2 focus:ring-teal-500'}}) }}
            <div class="text-red-600 text-sm">{{ form_errors(registrationForm.plainPassword) }}</div>
        </div>

        <div class="mb-6">
            {{ form_label(registrationForm.roles, 'Role', {'attr': {'class': 'block mb-1 font-semibold'}}) }}
            {{ form_widget(registrationForm.roles, {'attr': {'class': 'bg-slate-100 rounded-lg px-4 py-3 w-full text-black focus:outline-none focus:ring-2 focus:ring-teal-500'}}) }}
            <div class="text-red-600 text-sm">{{ form_errors(registrationForm.roles) }}</div>
        </div>



        <button type="submit" class="bg-pink-400 text-white w-full py-3 rounded-lg font-semibold hover:bg-pink-500">
            Ajouter cet animateur
        </button>

        {{ form_end(registrationForm) }}
    </div>
{% endblock %}
