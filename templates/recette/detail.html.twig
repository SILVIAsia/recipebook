{% extends 'base.html.twig' %}

{% block title %}
nom de la recette | {{ parent() }}
{% endblock %}

{% block body %}
    <h1> A nous Assietes  {{ recette.titre }}</h1>

    {% if recette.picture %}
    <div>
        <img src="{{ asset('uploads/images/'~recette.picture) }}"
             alt="Representation de recette {{ recette.titre }}"
             class="w-120 h-120 object-cover rounded">
    </div>
    {% endif %}

    <div>Description: {{ recette.description }}</div>
    <div>Temps de preparation: {{ recette.preparationTime }} min</div>
    <div>Temps de preparation:{{ recette.cooktime }}min</div>
    <div>Innvités: {{ recette.servings }}</div>
    <div>Date de realisation {{ recette.date | date("d-m-Y ") }}</div>
    <div> Difficulté {{ recette.difficulty }}</div>
    <div> Producteur Local{{ recette.producer }}</div>
    <div>{{ recette.published ? "oui" : "non" }}</div>
    <div>{{ recette.dateCreated | date("d-m-Y H:i") }}</div>


    <div>
        <a href="{{ path('recette_edit', {id:recette.id}) }}" class="bg-pink-400 text-white p-2 rounded">Modifier</a>

        <a href="{{ path('recette_delete', {
            'id': recette.id,
            'token': csrf_token('delete' ~ recette.id)
        }) }}" class="bg-pink-400 text-white p-2 rounded">  Supprimer</a>
    </div>

{#  todo: afichage de detail de la recette #}
{% endblock %}

