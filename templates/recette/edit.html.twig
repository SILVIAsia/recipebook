{% extends 'base.html.twig' %}


{% block title %} Modifier une recette "{{ recette.titre }}| {{ parent() }}  {% endblock %}


{% block body %}
    <h1>Modifier une recette</h1>


    <div class="text-gray-600 ml-33">
        {{ include('recette/_form.html.twig', {submitLabel: "Modifier la recette"} ) }}
    </div>

    {% if recette.picture %}
        <div>
            <img src="{{ asset('uploads/images/'~recette.picture) }}"
                 alt="Representation de recette {{ recette.titre }}"
                 class="w-80 h-80 object-cover rounded">
        </div>
    {% endif %}


{% endblock %}

